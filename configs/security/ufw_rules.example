#!/bin/bash
# UFW Firewall Rules for Armando AI Assistant
# ===========================================

# Enable UFW
ufw --force enable

# Allow SSH (port 22)
ufw allow ssh
ufw allow 22/tcp

# For future web interface (optional)
# ufw allow 80/tcp    # HTTP
# ufw allow 443/tcp   # HTTPS

# Default policies
ufw default deny incoming
ufw default allow outgoing

# Reload rules
ufw --force reload

# Show status
ufw status verbose
