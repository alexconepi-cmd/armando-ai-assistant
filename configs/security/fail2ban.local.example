# Fail2Ban Configuration for Armando AI Assistant
# ===============================================

[DEFAULT]
# Base configuration
bantime = 3600
findtime = 600
maxretry = 3
backend = auto

[sshd]
# SSH protection
enabled = true
port = ssh
filter = sshd
logpath = /var/log/auth.log
maxretry = 3
bantime = 3600

# Optional: Add protection for other services
# [nginx-http-auth]
# enabled = true
# port = http,https
# filter = nginx-http-auth
# logpath = /var/log/nginx/error.log
